{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window: open and read markdown files chosen by the user",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/Greg-Klein/MDora/releases/*" }]
    }
  ]
}
