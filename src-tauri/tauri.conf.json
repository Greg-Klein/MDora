{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDora",
  "version": "0.2.2",
  "identifier": "com.mdora.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MDora",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown",
        "description": "Markdown document",
        "mimeType": "text/markdown",
        "rank": "Alternate",
        "role": "Editor",
        "exportedType": {
          "identifier": "com.mdora.app.markdown",
          "conformsTo": ["public.plain-text"]
        }
      }
    ],
    "macOS": {
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 180 },
        "applicationFolderPosition": { "x": 480, "y": 180 }
      }
    }
  }
}
